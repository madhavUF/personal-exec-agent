# -----------------------------------------------------------------------------
# Core app settings (non-secret)
# Secrets are loaded from CREDENTIALS_FILE (default: credentials/.secrets.env)
# -----------------------------------------------------------------------------

# Path to secrets file (git-ignored)
CREDENTIALS_FILE=credentials/.secrets.env

# Display name used in the assistant
USER_DISPLAY_NAME=Your Name

# Google Nest — Device Access Console https://console.nest.google.com/products
# Enroll ($5 one-time), create a project, paste the Project ID here
# Format: enterprises/abc-123-xyz
NEST_PROJECT_ID=

# AgentGate location (key goes in credentials file)
AGENT_GATE_URL=http://localhost:8000

# Approval queue API protection key (store real value in credentials file)
# Used when APPROVAL_AUTH_MODE includes key-based auth.
APPROVAL_API_KEY=
# Approval auth mode:
# - key: require x-approval-key only
# - totp: require x-approval-totp only
# - key_or_totp: accept either key or TOTP
# - both: require both key and TOTP
APPROVAL_AUTH_MODE=key_or_totp

# LLM Provider — choose: claude (default) | groq | ollama | openai
MODEL_PROVIDER=claude
MODEL_NAME=claude-sonnet-4-6

# Groq routing tiers
GROQ_TIER1_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TIER2_MODEL=qwen/qwen3-32b
GROQ_TIER3_MODEL=moonshotai/kimi-k2-instruct-0905
CLAUDE_MODEL=claude-sonnet-4-6

# Ollama (only needed if MODEL_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434/v1

# Set to true if the model supports vision (image input)
MODEL_SUPPORTS_VISION=false

# OpenClaw / Clawdbot delegation (optional)
OPENCLAW_ENABLED=true
OPENCLAW_BIN=openclaw
OPENCLAW_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# Security hardening
# -----------------------------------------------------------------------------

# Master toggle for hardening features (approval gate, TOTP auth, strict egress).
# false = simple mode (no approval/TOTP enforcement, no strict egress blocks)
# true  = hardened mode
SECURITY_HARDENING=false

# Egress allowlist (comma-separated hosts or suffixes).
# Keep minimal for local-first safety.
EGRESS_ALLOWLIST=localhost,127.0.0.1,api.anthropic.com,api.groq.com,api.openai.com,accounts.google.com,oauth2.googleapis.com,googleapis.com,smartdevicemanagement.googleapis.com

# Public web research is disabled by default due to strict egress policy.
ALLOW_PUBLIC_WEB_RESEARCH=false

# -----------------------------------------------------------------------------
# Usage telemetry pricing (optional, per-1M tokens)
# -----------------------------------------------------------------------------
# Example:
# TELEMETRY_PRICING_JSON='{"groq":{"meta-llama/llama-4-scout-17b-16e-instruct":{"input":0.10,"output":0.30},"*":{"input":0.0,"output":0.0}},"claude":{"*":{"input":0.0,"output":0.0,"cacheRead":0.0,"cacheWrite":0.0}}}'
TELEMETRY_PRICING_JSON=

# -----------------------------------------------------------------------------
# Encrypted backups
# -----------------------------------------------------------------------------
BACKUP_OUTPUT_DIR=backups
BACKUP_PASSPHRASE=
