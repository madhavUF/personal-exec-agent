# Anthropic — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — create at https://console.cloud.google.com
# Enable: Gmail API + Google Calendar API
# Authorised redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Display name used in the assistant
USER_DISPLAY_NAME=Your Name

# Telegram bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# AgentGate — optional credential broker (see AgentGate/ folder)
# Uncomment to route Gmail/Calendar calls through AgentGate
# AGENT_GATE_URL=http://localhost:8787
# AGENT_GATE_KEY=dev-agent-key
