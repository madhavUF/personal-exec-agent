# Anthropic — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — create at https://console.cloud.google.com
# Enable: Gmail API + Google Calendar API
# Authorised redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Display name used in the assistant
USER_DISPLAY_NAME=Your Name

# Telegram bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Google Nest — Device Access Console https://console.nest.google.com/products
# Enroll ($5 one-time), create a project, paste the Project ID here
# Format: enterprises/abc-123-xyz
NEST_PROJECT_ID=

# AgentGate — built-in credential broker (runs inside the FastAPI server)
# The AI agent uses only this key; OAuth tokens never leave this process.
# Keep AGENT_GATE_URL pointing at localhost:8000 (same server).
AGENT_GATE_URL=http://localhost:8000
AGENT_GATE_KEY=dev-agent-key

# LLM Provider — choose: claude (default) | groq | ollama | openai
MODEL_PROVIDER=claude
MODEL_NAME=claude-sonnet-4-6

# Groq (only needed if MODEL_PROVIDER=groq)
# Get API key at https://console.groq.com
# When MODEL_PROVIDER=groq, queries are automatically routed to the cheapest capable tier:
#   Tier 1 (fast lookups, tool calls) → GROQ_TIER1_MODEL
#   Tier 2 (writing, summarisation)   → GROQ_TIER2_MODEL
#   Tier 3 (analysis, complex tasks)  → GROQ_TIER3_MODEL
#   Vision (any image query)          → Claude Sonnet (always)
GROQ_API_KEY=
GROQ_TIER1_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TIER2_MODEL=qwen/qwen3-32b
GROQ_TIER3_MODEL=moonshotai/kimi-k2-instruct-0905
CLAUDE_MODEL=claude-sonnet-4-6

# Ollama (only needed if MODEL_PROVIDER=ollama)
# Install Ollama from https://ollama.com, then: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434/v1

# OpenAI (only needed if MODEL_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Set to true if the model supports vision (image input)
MODEL_SUPPORTS_VISION=false
