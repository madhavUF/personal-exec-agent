# Copy to credentials/.secrets.env and fill real secrets.
# This file is intentionally git-ignored.

# Model/API keys
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...

# Google OAuth app secrets
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Telegram
TELEGRAM_BOT_TOKEN=

# AgentGate and approval security keys
AGENT_GATE_KEY=replace-with-strong-random-secret
APPROVAL_API_KEY=replace-with-strong-random-secret

# Optional TOTP secret for approval auth (base32, e.g. from `python -m pyotp --random-base32`)
# Use this with APPROVAL_AUTH_MODE=totp or key_or_totp in .env
APPROVAL_TOTP_SECRET=
